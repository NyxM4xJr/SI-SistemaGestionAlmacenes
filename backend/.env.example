# ============================================
# VARIABLES DE ENTORNO - BACKEND DJANGO
# ============================================
# Instrucciones:
# 1. Copiar este archivo a .env
# 2. Solicitar valores reales al Tech Lead
# 3. NUNCA subir .env a GitHub

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Django
SECRET_KEY=django-insecure-xxxxxxxxxxxxx
DEBUG=True

# ============================================
# Stripe (CU31)
# ============================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ============================================
# CICLO 5
# ============================================
# PayPal (CU36) — credenciales de https://developer.paypal.com (sandbox)
PAYPAL_CLIENT_ID=xxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxx
PAYPAL_MODE=sandbox
# Webhook ID (developer.paypal.com > tu app > Webhooks > URL apuntando a
# /api/pagos/paypal/webhook/, evento CHECKOUT.ORDER.APPROVED)
PAYPAL_WEBHOOK_ID=xxxxxxxxxxxxx

# Email vía API de Resend (CU33 y CU37) — NO usar SMTP: Railway bloquea
# las conexiones SMTP salientes (cuelga el worker hasta el WORKER TIMEOUT).
# Conseguir el API key en https://resend.com (Dashboard > API Keys).
RESEND_API_KEY=re_xxxxxxxxxxxxx
# Sin verificar un dominio propio en Resend, el remitente debe ser
# onboarding@resend.dev y solo se puede enviar al email del dueño de la cuenta.
DEFAULT_FROM_EMAIL=onboarding@resend.dev

# OpenAI (CU38 briefing proactivo, CU39 recetas con IA)
# Conseguir el API key en https://platform.openai.com (API Keys).
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
